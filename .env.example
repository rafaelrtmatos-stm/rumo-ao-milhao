GEMINI_API_KEY=

# API externa para converter DOCX em PDF com LibreOffice.
# Use no Vercel apontando para o Replit/Railway/Render:
# PDF_CONVERTER_API_URL=https://SEU-SERVIDOR/api/convert-docx-to-pdf
# PDF_CONVERTER_API_KEY=uma-chave-secreta-opcional
# No servidor conversor, use a mesma PDF_CONVERTER_API_KEY.
# LIBREOFFICE_PATH=/caminho/opcional/para/soffice
