{
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/index" }],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "attached_assets/**"
    }
  },
  "toolbar": {
    "defaultOpen": false
  }
}
