{
  "buildCommand": "vite build && esbuild api/index.ts --bundle --platform=node --format=cjs --outfile=api/index.js --external:pg-native --external:bufferutil --external:utf-8-validate",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "attached_assets/**"
    }
  }
}
